# Пример конфигурации окружения. Скопируй в .env и заполни реальными значениями.
# На Render задаются через: Dashboard → Service → Environment → Add Environment Variable

# Telegram бот для обратной связи (@minimaxapp_bot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwXyZ
TELEGRAM_CHAT_ID=987654321
